{
  "name": "deadlock_api_client",
  "version": "0.1.0",
  "description": "OpenAPI client for deadlock_api_client",
  "author": "OpenAPI-Generator Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/deadlock-api/openapi-clients.git"
  },
  "keywords": [
    "axios",
    "typescript",
    "openapi-client",
    "openapi-generator",
    "deadlock_api_client"
  ],
  "license": "Unlicense",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build"
  },
  "dependencies": {
    "axios": "^1.15.2"
  },
  "devDependencies": {
    "@types/node": "12.11.5 - 12.20.42",
    "typescript": "^4.0 || ^5.0"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./apis": {
      "types": "./dist/apis/index.d.ts",
      "import": "./dist/apis/index.js"
    },
    "./apis/*": {
      "types": "./dist/apis/*.d.ts",
      "import": "./dist/apis/*.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "import": "./dist/models/index.js"
    },
    "./models/*": {
      "types": "./dist/models/*.d.ts",
      "import": "./dist/models/*.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ]
}

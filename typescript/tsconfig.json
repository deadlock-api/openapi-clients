{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "typeRoots": [
      "node_modules/@types"
    ]
  },
  "include": [
    "apis",
    "models",
    "*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
